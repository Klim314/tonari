{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/node_modules",
			"!**/src/client",
			"!**/openapi.json",
			"!**/tsconfig*.json"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"style": {
				"useImportType": "off"
			}
		}
	}
}
