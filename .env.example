# Application Settings
APP_NAME=tonari-backend
ENV=dev
API_PORT=8087

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tonari

# Translation Settings
TRANSLATION_MODEL=gpt-4o-mini
TRANSLATION_CHUNK_CHARS=160
TRANSLATION_CONTEXT_SEGMENTS=3
TRANSLATION_API_BASE_URL=

# API Keys
# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API Key (https://openrouter.ai/keys) — used for Claude models
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Legacy API Key (for backward compatibility)
# This will be used as fallback for OpenAI if OPENAI_API_KEY is not set
TRANSLATION_API_KEY=

# Prompt Override Settings
PROMPT_OVERRIDE_SECRET=tonari-prompt-override-secret
PROMPT_OVERRIDE_TOKEN_TTL_SECONDS=600

# Available Models:
# OpenAI: gpt-5.5, gpt-5.4, gpt-5.3, gpt-5.2, gpt-5.1, gpt-5, gpt-5-mini, gpt-5-nano, gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo
# Claude (via OpenRouter): anthropic/claude-opus-4.7, anthropic/claude-sonnet-4.6, anthropic/claude-haiku-4.5
# Gemini: gemini-3-pro-preview, gemini-3-flash-preview, gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash, gemini-2.0-flash-lite

# Langfuse Observability (https://langfuse.com)
# Leave both keys blank to disable. Enabled automatically when both are set.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# Defaults to https://cloud.langfuse.com — override for self-hosted or US region.
# Variable name matches the upstream Langfuse SDK env var.
LANGFUSE_HOST=https://cloud.langfuse.com
